{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sundog",
  "account_id": "bc4564dd499c0a9b8a7bb79c9bd5ea6d",
  "compatibility_date": "2026-05-03",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "sundogs.app",
      "custom_domain": true,
    },
  ],
}
