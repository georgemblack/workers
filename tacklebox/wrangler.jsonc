{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tacklebox",
  "account_id": "d2c79054532b29379a02972214ef7e67",
  "compatibility_date": "2026-05-03",
  "assets": {
    "directory": "./public",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
  "routes": [
    {
      "pattern": "tackleboxapp.net",
      "custom_domain": true,
    },
  ],
}
