{
  "name": "idp",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "dryrun": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "typegen": "wrangler types --env-interface CloudflareBindings",
    "format": "prettier . --write",
    "db:migrate:local": "wrangler d1 migrations apply idp --local",
    "db:migrate": "wrangler d1 migrations apply idp --remote",
    "keygen": "node scripts/keygen.mjs"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.2.2",
    "hono": "^4.12.22",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "wrangler": "^4.94.0"
  }
}
